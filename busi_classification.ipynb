@torch.no_grad()
def collect_predictions(model, loader):
    model.eval()
    rows = []

    for images, labels, sample_ids, image_paths in tqdm(loader, leave=False):
        images = images.to(DEVICE)
        logits = model(images)
        probs = torch.softmax(logits, dim=1)
        preds = torch.argmax(probs, dim=1)
        confs = probs.max(dim=1).values

        for i in range(images.size(0)):
            pred_id = int(preds[i].item())
            row = {
                "sample_id": sample_ids[i],
                "image_path": image_paths[i],
                "true_label_id": int(labels[i].item()),
                "true_label_name": CLASS_NAMES[int(labels[i].item())],
                "pred_label_id": pred_id,
                "pred_label_name": CLASS_NAMES[pred_id],
                "confidence": float(confs[i].item()),
                "prob_normal": float(probs[i, 0].item()),
                "prob_benign": float(probs[i, 1].item()),
                "prob_malignant": float(probs[i, 2].item()),
                "low_confidence": bool(float(confs[i].item()) < 0.60),
            }
            rows.append(row)

    return pd.DataFrame(rows)

pred_df = collect_predictions(model, test_loader)
pred_df.to_csv(OUT_DIR / "test_predictions.csv", index=False)

