import os
import re
import json
import random
from pathlib import Path

import numpy as np
import pandas as pd
from PIL import Image

import matplotlib.pyplot as plt

import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader

from torchvision import transforms, models

from sklearn.model_selection import train_test_split
from sklearn.metrics import (
    accuracy_score,
    f1_score,
    precision_recall_fscore_support,
    confusion_matrix,
    roc_auc_score,
)
from sklearn.preprocessing import label_binarize

from tqdm.auto import tqdm

SEED = 42
IMAGE_SIZE = 224
BATCH_SIZE = 16
EPOCHS = 20
LR = 1e-4
WEIGHT_DECAY = 1e-4
NUM_WORKERS = 2
TEST_SIZE = 0.15
VAL_SIZE = 0.15
MODEL_NAME = "resnet18"   # можно поменять на "resnet50"
USE_PRETRAINED = True

CLASS_NAMES = ["normal", "benign", "malignant"]
LABEL_TO_ID = {"normal": 0, "benign": 1, "malignant": 2}

OUT_DIR = Path("/kaggle/working/busi_simple")
OUT_DIR.mkdir(parents=True, exist_ok=True)

DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")

print("Device:", DEVICE)
print("Output dir:", OUT_DIR)

def set_seed(seed=42):
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

set_seed(SEED)

def build_busi_dataframe():
    root = Path("/kaggle/input")
    rows = []

    for p in root.rglob("*.png"):
        stem_lower = p.stem.lower()

        # пропускаем маски
        if "_mask" in stem_lower:
            continue

        parts_lower = [x.lower() for x in p.parts]
        label_name = None
        for cname in CLASS_NAMES:
            if cname in parts_lower:
                label_name = cname
                break

        if label_name is None:
            continue

        rows.append({
            "image_path": str(p),
            "label_name": label_name,
            "label_id": LABEL_TO_ID[label_name],
            "sample_id": f"{label_name}__{p.stem}"
        })

    if len(rows) == 0:
        raise FileNotFoundError(
            "Не найдено ни одного BUSI image file. "
            "Проверь, что датасет добавлен в Kaggle notebook."
        )

    df = pd.DataFrame(rows).drop_duplicates(subset=["image_path"]).reset_index(drop=True)
    return df

df = build_busi_dataframe()
df.to_csv(OUT_DIR / "all_data.csv", index=False)

print("Total images:", len(df))
print(df["label_name"].value_counts())

train_df, temp_df = train_test_split(
    df,
    test_size=TEST_SIZE + VAL_SIZE,
    stratify=df["label_id"],
    random_state=SEED,
)

rel_test = TEST_SIZE / (TEST_SIZE + VAL_SIZE)
val_df, test_df = train_test_split(
    temp_df,
    test_size=rel_test,
    stratify=temp_df["label_id"],
    random_state=SEED,
)

train_df = train_df.reset_index(drop=True)
val_df = val_df.reset_index(drop=True)
test_df = test_df.reset_index(drop=True)

train_df.to_csv(OUT_DIR / "train.csv", index=False)
val_df.to_csv(OUT_DIR / "val.csv", index=False)
test_df.to_csv(OUT_DIR / "test.csv", index=False)

print("\nSplit sizes:")
print("Train:", len(train_df))
print("Val:  ", len(val_df))
print("Test: ", len(test_df))

fig, axes = plt.subplots(1, 3, figsize=(12, 4))
for i, cname in enumerate(CLASS_NAMES):
    sample = df[df["label_name"] == cname].iloc[0]
    img = Image.open(sample["image_path"]).convert("RGB")
    axes[i].imshow(img)
    axes[i].set_title(cname)
    axes[i].axis("off")
plt.tight_layout()
plt.savefig(OUT_DIR / "dataset_samples.png", dpi=200)
plt.show()

imagenet_mean = [0.485, 0.456, 0.406]
imagenet_std = [0.229, 0.224, 0.225]

train_transform = transforms.Compose([
    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),
    transforms.RandomHorizontalFlip(),
    transforms.RandomVerticalFlip(),
    transforms.RandomRotation(10),
    transforms.ColorJitter(brightness=0.1, contrast=0.1),
    transforms.ToTensor(),
    transforms.Normalize(imagenet_mean, imagenet_std),
])

eval_transform = transforms.Compose([
    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),
    transforms.ToTensor(),
    transforms.Normalize(imagenet_mean, imagenet_std),
])

class BUSIClassificationDataset(Dataset):
    def __init__(self, dataframe, transform=None):
        self.df = dataframe.reset_index(drop=True)
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        row = self.df.iloc[idx]
        image = Image.open(row["image_path"]).convert("RGB")
        label = int(row["label_id"])

        if self.transform is not None:
            image = self.transform(image)

        return image, label, row["sample_id"], row["image_path"]

train_ds = BUSIClassificationDataset(train_df, transform=train_transform)
val_ds = BUSIClassificationDataset(val_df, transform=eval_transform)
test_ds = BUSIClassificationDataset(test_df, transform=eval_transform)

train_loader = DataLoader(
    train_ds,
    batch_size=BATCH_SIZE,
    shuffle=True,
    num_workers=NUM_WORKERS,
    pin_memory=torch.cuda.is_available(),
)

val_loader = DataLoader(
    val_ds,
    batch_size=BATCH_SIZE,
    shuffle=False,
    num_workers=NUM_WORKERS,
    pin_memory=torch.cuda.is_available(),
)

test_loader = DataLoader(
    test_ds,
    batch_size=BATCH_SIZE,
    shuffle=False,
    num_workers=NUM_WORKERS,
    pin_memory=torch.cuda.is_available(),
)

print("\nBatches:")
print("Train:", len(train_loader))
print("Val:  ", len(val_loader))
print("Test: ", len(test_loader))

def build_model(model_name="resnet18", num_classes=3, use_pretrained=True):
    weights = None

    try:
        if model_name == "resnet18":
            if use_pretrained:
                weights = models.ResNet18_Weights.DEFAULT
            model = models.resnet18(weights=weights)
            in_features = model.fc.in_features
            model.fc = nn.Linear(in_features, num_classes)

        elif model_name == "resnet50":
            if use_pretrained:
                weights = models.ResNet50_Weights.DEFAULT
            model = models.resnet50(weights=weights)
            in_features = model.fc.in_features
            model.fc = nn.Linear(in_features, num_classes)

        else:
            raise ValueError("Unsupported model name")
    except Exception as e:
        print(f"[WARN] Could not load pretrained weights: {e}")
        if model_name == "resnet18":
            model = models.resnet18(weights=None)
            in_features = model.fc.in_features
            model.fc = nn.Linear(in_features, num_classes)
        elif model_name == "resnet50":
            model = models.resnet50(weights=None)
            in_features = model.fc.in_features
            model.fc = nn.Linear(in_features, num_classes)

    return model

model = build_model(MODEL_NAME, num_classes=3, use_pretrained=USE_PRETRAINED).to(DEVICE)

class_counts = train_df["label_id"].value_counts().sort_index()
total = class_counts.sum()
class_weights = torch.tensor(
    [total / (3.0 * class_counts.get(i, 1)) for i in range(3)],
    dtype=torch.float32,
    device=DEVICE,
)

criterion = nn.CrossEntropyLoss(weight=class_weights)
optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)
scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(
    optimizer,
    mode="max",
    factor=0.5,
    patience=2,
)

print("Class weights:", class_weights.detach().cpu().tolist())

def compute_metrics(y_true, y_pred, y_prob):
    y_true = np.asarray(y_true)
    y_pred = np.asarray(y_pred)
    y_prob = np.asarray(y_prob)

    acc = accuracy_score(y_true, y_pred)
    macro_f1 = f1_score(y_true, y_pred, average="macro")
    prec, rec, f1s, _ = precision_recall_fscore_support(
        y_true, y_pred, labels=[0, 1, 2], zero_division=0
    )

    metrics = {
        "accuracy": float(acc),
        "macro_f1": float(macro_f1),
        "per_class_precision": {CLASS_NAMES[i]: float(prec[i]) for i in range(3)},
        "per_class_recall": {CLASS_NAMES[i]: float(rec[i]) for i in range(3)},
        "per_class_f1": {CLASS_NAMES[i]: float(f1s[i]) for i in range(3)},
    }

    try:
        y_true_bin = label_binarize(y_true, classes=[0, 1, 2])
        auc = roc_auc_score(y_true_bin, y_prob, average="macro", multi_class="ovr")
        metrics["macro_ovr_roc_auc"] = float(auc)
    except Exception:
        metrics["macro_ovr_roc_auc"] = None

    return metrics

def run_one_epoch(model, loader, criterion, optimizer=None):
    is_train = optimizer is not None
    model.train() if is_train else model.eval()

    running_loss = 0.0
    total_count = 0

    y_true_all = []
    y_pred_all = []
    y_prob_all = []

    for images, labels, _, _ in tqdm(loader, leave=False):
        images = images.to(DEVICE)
        labels = labels.to(DEVICE)

        if is_train:
            optimizer.zero_grad()

        with torch.set_grad_enabled(is_train):
            logits = model(images)
            loss = criterion(logits, labels)

            if is_train:
                loss.backward()
                optimizer.step()

        probs = torch.softmax(logits, dim=1)
        preds = torch.argmax(probs, dim=1)

        bs = images.size(0)
        running_loss += loss.item() * bs
        total_count += bs

        y_true_all.extend(labels.detach().cpu().numpy().tolist())
        y_pred_all.extend(preds.detach().cpu().numpy().tolist())
        y_prob_all.extend(probs.detach().cpu().numpy().tolist())

    metrics = compute_metrics(y_true_all, y_pred_all, y_prob_all)
    metrics["loss"] = running_loss / max(total_count, 1)

    return metrics, y_true_all, y_pred_all, y_prob_all

best_val_f1 = -1.0
best_model_path = OUT_DIR / "best_model.pt"
history = []
patience = 3
bad_epochs = 0

print("\nStarting training...\n")

for epoch in range(1, EPOCHS + 1):
    train_metrics, _, _, _ = run_one_epoch(model, train_loader, criterion, optimizer=optimizer)
    val_metrics, _, _, _ = run_one_epoch(model, val_loader, criterion, optimizer=None)

    scheduler.step(val_metrics["macro_f1"])

    history.append({
        "epoch": epoch,
        "train_loss": train_metrics["loss"],
        "train_acc": train_metrics["accuracy"],
        "train_f1": train_metrics["macro_f1"],
        "val_loss": val_metrics["loss"],
        "val_acc": val_metrics["accuracy"],
        "val_f1": val_metrics["macro_f1"],
        "lr": optimizer.param_groups[0]["lr"],
    })

    print(
        f"Epoch {epoch:02d}/{EPOCHS} | "
        f"train_loss={train_metrics['loss']:.4f} train_f1={train_metrics['macro_f1']:.4f} | "
        f"val_loss={val_metrics['loss']:.4f} val_f1={val_metrics['macro_f1']:.4f}"
    )

    if val_metrics["macro_f1"] > best_val_f1:
        best_val_f1 = val_metrics["macro_f1"]
        bad_epochs = 0
        torch.save(model.state_dict(), best_model_path)
        print(f"Saved best model -> {best_model_path}")
    else:
        bad_epochs += 1

    if bad_epochs >= patience:
        print("Early stopping triggered.")
        break

history_df = pd.DataFrame(history)
history_df.to_csv(OUT_DIR / "history.csv", index=False)

model.load_state_dict(torch.load(best_model_path, map_location=DEVICE))

test_metrics, y_true, y_pred, y_prob = run_one_epoch(model, test_loader, criterion, optimizer=None)

print("\nTEST METRICS")
print(json.dumps(test_metrics, indent=2))

cm = confusion_matrix(y_true, y_pred, labels=[0, 1, 2])

